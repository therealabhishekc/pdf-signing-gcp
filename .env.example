# ── Foundry connection ────────────────────────────────────────────────────────
VITE_FOUNDRY_STACK=https://foundry.example.com
VITE_CLIENT_ID=your-oauth-client-id-here
VITE_CLIENT_SECRET=your-oauth-client-secret-here

# ── MongoDB (for temporary signed PDF storage) ──────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pdfstore

# ── Foundry Action (auto-attach signed PDF) ──────────────────────────────────
FOUNDRY_ONTOLOGY_API_NAME=your-ontology-api-name
FOUNDRY_ACTION_API_NAME=attach-pdf-from-db
